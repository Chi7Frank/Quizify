{
  "name": "assessment-platform",
  "version": "1.0.0",
  "description": "Interactive Online Assessment Platform - HCI Case Study",
  "main": "index.js",
  "scripts": {
    "install:all": "npm install && cd backend && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npx live-server --port=5500 --no-browser",
    "start": "cd backend && npm start",
    "seed": "cd backend && npm run seed",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "assessment",
    "education",
    "quiz",
    "exam",
    "hci",
    "accessibility"
  ],
  "author": "Assessment Platform Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
